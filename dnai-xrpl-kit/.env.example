# XRPL testnet. Get SEED from: node scripts/create-wallet.js
XRPL_WSS=wss://s.altnet.rippletest.net:51233
SEED=sEd_your_testnet_seed
DEST=r_resource_or_seller_address
CURRENCY=XRP            # or RLUSD
VALUE=10                # 10 XRP, or e.g. 299 for RLUSD
# RLUSD_ISSUER=r_rlusd_issuer_on_testnet   # required if CURRENCY=RLUSD (set up a trustline first)
# ACCESS_REF=0x...        # DNaI access reference (e.g. a dataset contentHash). If unset, pay script hashes ACCESS_JSON.
# ACCESS_JSON={"datasetId":2,"buyer":"agentX"}
# SOURCE_TAG=4200
